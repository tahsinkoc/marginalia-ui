{
  "name": "@ulib/ui",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "style": "./dist/styles.css",
  "sideEffects": [
    "./dist/styles.css"
  ],
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "react-server": "./dist/index.server.js",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": {
      "default": "./dist/styles.css"
    }
  },
  "scripts": {
    "build": "npm run clean && tsup && npm run build:css",
    "build:css": "tailwindcss -c ./tailwind.config.cjs -i ./src/styles/theme.css -o ./dist/styles.css --minify",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "dev": "concurrently -n js,css -c auto \"npm:dev:js\" \"npm:dev:css\"",
    "dev:js": "tsup --watch",
    "dev:css": "tailwindcss -c ./tailwind.config.cjs -i ./src/styles/theme.css -o ./dist/styles.css --watch",
    "test": "vitest run"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "react-day-picker": "^9.14.0",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "jsdom": "^27.2.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "3.4.18",
    "tsup": "^8.5.1",
    "vitest": "^4.1.0"
  }
}
